# Copy this file to .env and fill in your real values.
# Get your secret key from https://dashboard.stripe.com/apikeys
# Use the sk_test_... key while testing, sk_live_... only once you're ready for real charges.

STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY

# Only needed once you set up a webhook endpoint in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

PORT=4242
